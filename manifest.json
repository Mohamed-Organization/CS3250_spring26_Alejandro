{
    "manifest_version": 2,
    "name": "Anonymous Theme Switcher",
    "version": "1.0.0",
    "description": "Changes theme groups.",
    "author": "Team Anonymous",
    "developer": { 
        "name": "Ramin, Daniel, Julian, Alejandro, Moe" 
    },

    "browser_action": {
    "default_popup": "src/popup.html",
    "default_title": "Anonymous Theme Switcher"
    },

   // "background": {
     //   "page": "background-page.html",
       // "persistent": true
    //},

    "permissions": [
    "<all_urls>", "storage", "management", "theme", "alarms", "tabs"
    ],
    
    "browser_specific_settings": {
        "gecko": {
            "id": "anonymous_theme_switcher@team-anonymous.org",
            "strict_min_version": "60.0"
        }
    }
}